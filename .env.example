APP_NAME="CRM Operativo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Base de datos ---
# Para arrancar en LOCAL sin instalar MySQL, usa SQLite (por defecto abajo).
# Para producción, cambia a mysql (ver DEPLOYMENT.md).
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=crm_operativo
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- CORS / Sanctum SPA ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,localhost:5173,127.0.0.1,127.0.0.1:8000,127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Mailgun (correo transaccional) ---
MAIL_MAILER=log
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAIL_FROM_ADDRESS="no-reply@crm-operativo.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- Twilio (WhatsApp / SMS) ---
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Webhook de captura externa de leads ---
WEBHOOK_SIGNING_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

VITE_API_URL=
